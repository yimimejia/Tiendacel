modules = ["nodejs-20"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
NODE_ENV = "development"
PORT = "8000"
CORS_ORIGIN = "http://localhost:5000"
FRONTEND_URL = "http://localhost:5000"
APP_BASE_URL = "http://localhost:8000"
UPLOAD_DIR = "uploads"
MAX_UPLOAD_MB = "5"
SERVE_FRONTEND = "false"
FRONTEND_DIST_PATH = "client/dist"
VITE_API_URL = "/api"
VITE_APP_NAME = "Vibran Tech"
VITE_PUBLIC_BASE_URL = "/"
VITE_PORT = "5000"
VITE_PREVIEW_PORT = "4173"
JWT_SECRET = "e03328f85774c11e65cfa5f6b9958d5121092e5a996024ddde233d6411e3300c"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Backend API"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Backend API"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev -w server"
waitForPort = 8000

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev -w client"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8000
externalPort = 8000
