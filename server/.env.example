# Runtime
NODE_ENV=development
PORT=4000

# Database (PostgreSQL)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/vibran_tech

# Security
JWT_SECRET=CAMBIA_ESTA_LLAVE_POR_UNA_DE_AL_MENOS_32_CARACTERES

# Network / CORS
# Multiple origins are supported using commas.
CORS_ORIGIN=http://localhost:5173
FRONTEND_URL=http://localhost:5173
APP_BASE_URL=http://localhost:4000

# Uploads
# Relative path is resolved from repo root.
UPLOAD_DIR=uploads
MAX_UPLOAD_MB=5

# Optional: serve frontend build from backend in production
SERVE_FRONTEND=false
FRONTEND_DIST_PATH=client/dist
